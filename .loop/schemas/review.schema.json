{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["blocking", "summary", "findings"],
  "properties": {
    "blocking": { "type": "boolean" },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "acceptanceIds", "file", "line", "problem", "fix"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "acceptanceIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 0 },
          "problem": { "type": "string" },
          "fix": { "type": "string" }
        }
      }
    }
  }
}
