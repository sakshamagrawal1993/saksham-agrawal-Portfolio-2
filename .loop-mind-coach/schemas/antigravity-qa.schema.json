{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["acceptanceResults", "summary"],
  "properties": {
    "summary": { "type": "string" },
    "acceptanceResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL", "BLOCKED", "NOT_TESTED"]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
