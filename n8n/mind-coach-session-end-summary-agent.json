        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"case_notes_base\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"presenting_concern\": {\n          \"type\": \"string\"\n        },\n        \"dynamic_theme\": {\n          \"type\": \"string\"\n        },\n        \"phase_progress\": {\n          \"type\": \"string\"\n        }\n      },\n      \"required\": [\n        \"presenting_concern\",\n        \"dynamic_theme\",\n        \"phase_progress\"\n      ]\n    },\n    \"session_summary\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"title\": {\n          \"type\": \"string\"\n        },\n        \"opening_reflection\": {\n          \"type\": \"string\"\n        },\n        \"quote_of_the_day\": {\n          \"type\": \"string\"\n        },\n        \"energy_shift\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"start\": {\n              \"type\": \"string\"\n            },\n            \"end\": {\n              \"type\": \"string\"\n            }\n          },\n          \"required\": [\n            \"start\",\n            \"end\"\n          ]\n        },\n        \"psychological_flexibility\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"self_awareness\": {\n              \"type\": \"integer\",\n              \"minimum\": 0,\n              \"maximum\": 100\n            },\n            \"observation\": {\n              \"type\": \"integer\",\n              \"minimum\": 0,\n              \"maximum\": 100\n            },\n            \"physical_awareness\": {\n              \"type\": \"integer\",\n              \"minimum\": 0,\n              \"maximum\": 100\n            },\n            \"core_values\": {\n              \"type\": \"integer\",\n              \"minimum\": 0,\n              \"maximum\": 100\n            },\n            \"relationships\": {\n              \"type\": \"integer\",\n              \"minimum\": 0,\n              \"maximum\": 100\n            }\n          },\n          \"required\": [\n            \"self_awareness\",\n            \"observation\",\n            \"physical_awareness\",\n            \"core_values\",\n            \"relationships\"\n          ]\n        },\n        \"self_compassion_score\": {\n          \"type\": \"integer\",\n          \"minimum\": 0,\n          \"maximum\": 100\n        }\n      },\n      \"required\": [\n        \"title\",\n        \"opening_reflection\",\n        \"quote_of_the_day\",\n        \"energy_shift\",\n        \"psychological_flexibility\",\n        \"self_compassion_score\"\n      ]\n    },\n    \"extracted_tasks\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"task_type\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"journaling\",\n              \"somatic_exercise\",\n              \"cognitive_reframing\",\n              \"behavioral_exposure\",\n              \"situational_prep\",\n              \"general\"\n            ]\n          },\n          \"dynamic_title\": {\n            \"type\": \"string\"\n          },\n          \"dynamic_description\": {\n            \"type\": \"string\"\n          },\n          \"frequency\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"daily\",\n              \"weekly\",\n              \"situational\",\n              \"once\"\n            ]\n          },\n          \"suggested_duration_days\": {\n            \"type\": \"integer\",\n            \"minimum\": 1,\n            \"maximum\": 90\n          }\n        },\n        \"required\": [\n          \"task_type\",\n          \"dynamic_title\",\n          \"dynamic_description\",\n          \"frequency\",\n          \"suggested_duration_days\"\n        ]\n      }\n    }\n  },\n  \"required\": [\n    \"case_notes_base\",\n    \"session_summary\",\n    \"extracted_tasks\"\n  ]\n}"
