        "jsCode": "function parseMaybeJson(value) {\n  if (typeof value !== 'string') return null;\n  try { return JSON.parse(value); } catch { return null; }\n}\n\nconst root = $json || {};\nconst body = typeof root.body === 'string' ? (parseMaybeJson(root.body) || {}) : (root.body || {});\nconst d = (body && typeof body === 'object' && Object.keys(body).length > 0) ? body : root;\n\nconst systemPrompt = [\n  'You are a clinical supervisor generating post-session summary and tasks.',\n  'Use transcript + profile + phase context + assessments + tasks + mood context.',\n  'No date hallucinations. Return ONLY valid JSON.'\n].join('\\n');\n\nconst userPrompt = [\n  'SESSION CONTEXT:', JSON.stringify({ profile: d.profile || {}, session: d.session || {}, phase_context: d.phase_context || {}, active_tasks: d.active_tasks || [], assessments: d.assessments || [], mood_entries: d.mood_entries || [] }),\n  '', 'MESSAGES:', JSON.stringify(d.messages || []),\n  '', 'TRANSCRIPT:', d.transcript || '',\n  '', 'Return JSON schema:',\n  '{',\n  '  \"case_notes_base\": { \"presenting_concern\": \"string\", \"dynamic_theme\": \"string\", \"phase_progress\": \"string\" },',\n  '  \"session_summary\": { \"title\": \"string\", \"opening_reflection\": \"string\", \"quote_of_the_day\": \"string\", \"energy_shift\": { \"start\": \"string\", \"end\": \"string\" }, \"psychological_flexibility\": { \"self_awareness\": 0, \"observation\": 0, \"physical_awareness\": 0, \"core_values\": 0, \"relationships\": 0 }, \"self_compassion_score\": 0 },',\n  '  \"extracted_tasks\": [{ \"task_type\": \"journaling | somatic_exercise | cognitive_reframing | behavioral_exposure | situational_prep | general\", \"dynamic_title\": \"string\", \"dynamic_description\": \"string\", \"frequency\": \"daily | weekly | situational | once\", \"suggested_duration_days\": 7 }]',\n  '}'\n].join('\\n');\n\nreturn [{ json: { systemPrompt, userPrompt } }];"
      },
