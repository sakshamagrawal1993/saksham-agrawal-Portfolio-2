{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://libertymd.example/schemas/n8n/diagnosis-response-v1.json",
  "title": "LibertyMD Diagnosis Response v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "ui_state",
    "differential_diagnosis",
    "confidence_score",
    "diagnosis_ready",
    "valid_report",
    "evidence_score",
    "sufficient_evidence",
    "validation_reason"
  ],
  "properties": {
    "ui_state": { "type": "string", "enum": ["report_ready", "report_invalid"] },
    "headline": { "type": "string" },
    "patient_summary": { "type": "string" },
    "clinical_context": {
      "type": "object",
      "properties": {
        "incremental_summary": { "type": "object" },
        "clinical_reasoning_state": { "type": "object" }
      },
      "additionalProperties": true
    },
    "model_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "differential_diagnosis": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["rank", "full_name", "common_name", "confidence", "supporting_evidence", "conflicting_evidence", "reason"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1, "maximum": 5 },
          "full_name": { "type": "string", "minLength": 1 },
          "common_name": { "type": "string", "minLength": 1 },
          "confidence": {
            "anyOf": [
              { "type": "number", "minimum": 0, "maximum": 100 },
              { "type": "string", "pattern": "^(100|[0-9]{1,2})(\\.[0-9]+)?%?$" }
            ]
          },
          "supporting_evidence": { "type": "array", "items": { "type": "string" } },
          "conflicting_evidence": { "type": "array", "items": { "type": "string" } },
          "reason": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "emergency": { "type": "string" }
        }
      }
    },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "diagnosis_ready": { "type": "boolean" },
    "valid_report": { "type": "boolean" },
    "evidence_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "sufficient_evidence": { "type": "boolean" },
    "validation_reason": {
      "type": "string",
      "enum": ["validated", "insufficient_clinical_information", "empty_differential", "low_diagnostic_confidence"]
    },
    "error": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": { "properties": { "valid_report": { "const": true } }, "required": ["valid_report"] },
      "then": {
        "properties": {
          "ui_state": { "const": "report_ready" },
          "diagnosis_ready": { "const": true },
          "differential_diagnosis": { "type": "array", "minItems": 1 },
          "confidence_score": { "type": "number", "minimum": 60 },
          "evidence_score": { "type": "integer", "minimum": 65 },
          "sufficient_evidence": { "const": true },
          "validation_reason": { "const": "validated" }
        }
      }
    },
    {
      "if": { "properties": { "valid_report": { "const": false } }, "required": ["valid_report"] },
      "then": {
        "properties": {
          "ui_state": { "const": "report_invalid" },
          "diagnosis_ready": { "const": false }
        }
      }
    }
  ]
}
